<?xml version="1.0" encoding="utf-8"?>
<Patch>
	<Operation Class="PatchOperationSequence">
		<operations>

			<!-- Patch apparel bulk and stats -->

			<li Class="PatchOperationAdd">
				<xpath>Defs/ThingDef[
						defName="Mousekin_ApparelSettlerOutfit" or 
						defName="Mousekin_ApparelWorkerOutfit"
					]/statBases</xpath>
				<value>
					<Bulk>1.5</Bulk>
					<WornBulk>1</WornBulk>
				</value>
			</li>
			
			<li Class="PatchOperationAdd">
				<xpath>Defs/ThingDef[
						defName="Mousekin_ApparelCraftsmanOutfit" or
						defName="Mousekin_ApparelGambeson" or
						defName="Mousekin_ApparelNunHabit" or
						defName="Mousekin_ApparelPriestCassock"
					]/statBases</xpath>
				<value>
					<Bulk>2</Bulk>
					<WornBulk>1.5</WornBulk>
				</value>
			</li>
			
			<li Class="PatchOperationAdd">
				<xpath>Defs/ThingDef[
						defName="Mousekin_ApparelGuardenerGown" or 
						defName="Mousekin_ApparelSettlerDress" or
						defName="Mousekin_ApparelWorkerDress"
					]/statBases</xpath>
				<value>
					<Bulk>3</Bulk>
					<WornBulk>3</WornBulk>
				</value>
			</li>
			
			<li Class="PatchOperationAdd">
				<xpath>Defs/ThingDef[defName="Mousekin_ApparelKnightCommanderCape"]/statBases</xpath>
				<value>
					<Bulk>3.5</Bulk>
					<WornBulk>1.5</WornBulk>
				</value>
			</li>
			
			<li Class="PatchOperationAdd">
				<xpath>Defs/ThingDef[
						defName="Mousekin_ApparelCloak" or 
						defName="Mousekin_ApparelGuardenerRobe" or
						defName="Mousekin_ArmorCuirass"
					]/statBases</xpath>
				<value>
					<Bulk>5</Bulk>
					<WornBulk>1.5</WornBulk>
				</value>
			</li>

			<li Class="PatchOperationAdd">
				<xpath>Defs/ThingDef[defName="Mousekin_ArmorPlate"]/statBases</xpath>
				<value>
					<Bulk>50</Bulk>
					<WornBulk>10</WornBulk>
				</value>
			</li>

			<li MayRequire="Ludeon.RimWorld.Biotech" Class="PatchOperationAdd">
				<xpath>Defs/ThingDef[
						defName="Mousekin_ApparelChildDress" or 
						defName="Mousekin_ApparelChildOutfit"
					]/statBases</xpath>
				<value>
					<Bulk>0.75</Bulk>
					<WornBulk>0.75</WornBulk>
				</value>
			</li>
			
			<li Class="PatchOperationAdd">
				<xpath>Defs/ThingDef[defName="Mousekin_ApparelGambeson"]/statBases</xpath>
				<value>
					<ArmorRating_Sharp>0.06</ArmorRating_Sharp>
				</value>
			</li>

			<li Class="PatchOperationReplace">
				<xpath>Defs/ThingDef[defName="Mousekin_ApparelGambeson"]/statBases/ArmorRating_Blunt</xpath>
				<value>
					<ArmorRating_Blunt>0.09</ArmorRating_Blunt>
				</value>
			</li>

			<li Class="PatchOperationReplace">
				<xpath>Defs/ThingDef[defName="Mousekin_ArmorCuirass"]/statBases/ArmorRating_Sharp</xpath>
				<value>
					<ArmorRating_Sharp>2.6</ArmorRating_Sharp>
				</value>
			</li>

			<li Class="PatchOperationReplace">
				<xpath>Defs/ThingDef[defName="Mousekin_ArmorCuirass" ]/statBases/ArmorRating_Blunt</xpath>
				<value>
					<ArmorRating_Blunt>3.4</ArmorRating_Blunt>
				</value>
			</li>

			<li Class="PatchOperationReplace">
				<xpath>Defs/ThingDef[defName="Mousekin_ArmorPlate"]/statBases/ArmorRating_Sharp</xpath>
				<value>
					<ArmorRating_Sharp>3.0</ArmorRating_Sharp>
				</value>
			</li>

			<li Class="PatchOperationReplace">
				<xpath>Defs/ThingDef[defName="Mousekin_ArmorPlate" ]/statBases/ArmorRating_Blunt</xpath>
				<value>
					<ArmorRating_Blunt>4.5</ArmorRating_Blunt>
				</value>
			</li>

			<li Class="PatchOperationReplace">
				<xpath>Defs/ThingDef[
						defName="Mousekin_ApparelGuardenerGown" or
						defName="Mousekin_ApparelNunHabit" or
						defName="Mousekin_ApparelPriestCassock" or
						defName="Mousekin_ApparelSettlerDress" or 
						defName="Mousekin_ApparelSettlerOutfit" or
						defName="Mousekin_ApparelWorkerDress" or
						defName="Mousekin_ApparelWorkerOutfit"
					]/statBases/StuffEffectMultiplierArmor</xpath>
				<value>
					<StuffEffectMultiplierArmor>1</StuffEffectMultiplierArmor>
				</value>
			</li>
			
			<li Class="PatchOperationReplace">
				<xpath>Defs/ThingDef[defName="Mousekin_ApparelCraftsmanOutfit"]/statBases/StuffEffectMultiplierArmor</xpath>
				<value>
					<StuffEffectMultiplierArmor>2</StuffEffectMultiplierArmor>
				</value>
			</li>
			
			<li Class="PatchOperationReplace">
				<xpath>Defs/ThingDef[
						defName="Mousekin_ApparelCloak" or
						defName="Mousekin_ApparelGambeson" or 
						defName="Mousekin_ApparelGuardenerRobe" or
						defName="Mousekin_ApparelKnightCommanderCape"
					]/statBases/StuffEffectMultiplierArmor</xpath>
				<value>
					<StuffEffectMultiplierArmor>4</StuffEffectMultiplierArmor>
				</value>
			</li>
			
			<li MayRequire="Ludeon.RimWorld.Biotech" Class="PatchOperationReplace">
				<xpath>Defs/ThingDef[
						defName="Mousekin_ApparelChildDress" or 
						defName="Mousekin_ApparelChildOutfit"
					]/statBases/StuffEffectMultiplierArmor</xpath>
				<value>
					<StuffEffectMultiplierArmor>1</StuffEffectMultiplierArmor>
				</value>
			</li>
			
			<!-- Patch headgear bulk and stats -->
			
			<li Class="PatchOperationAdd">
				<xpath>Defs/ThingDef[
						defName="Mousekin_HatHeadscarf" or 
						defName="Mousekin_HatNunVeil"
					]/statBases</xpath>
				<value>
					<Bulk>0.5</Bulk>
					<WornBulk>0.5</WornBulk>
				</value>
			</li>
			
			<li Class="PatchOperationAdd">
				<xpath>Defs/ThingDef[
						defName="Mousekin_HatStraw" or
						defName="Mousekin_HatWoodsman"
					]/statBases</xpath>
				<value>
					<Bulk>1</Bulk>
					<WornBulk>1</WornBulk>
				</value>
			</li>
			
			<li Class="PatchOperationAdd">
				<xpath>Defs/ThingDef[
						defName="Mousekin_HelmetKettle" or
						defName="Mousekin_HelmetMorion"
					]/statBases</xpath>
				<value>
					<Bulk>4</Bulk>
					<WornBulk>1</WornBulk>
				</value>
			</li>

			<li Class="PatchOperationAdd">
				<xpath>Defs/ThingDef[
						defName="Mousekin_HelmetKnight" or
						defName="Mousekin_HelmetKnightCommander"
					]/statBases</xpath>
				<value>
					<Bulk>5</Bulk>
					<WornBulk>1</WornBulk>
				</value>
			</li>

			<li Class="PatchOperationReplace">
				<xpath>Defs/ThingDef[defName="Mousekin_HatNunVeil"]/statBases/StuffEffectMultiplierArmor</xpath>
				<value>
					<StuffEffectMultiplierArmor>1</StuffEffectMultiplierArmor>
				</value>
			</li>
			
			<li Class="PatchOperationReplace">
				<xpath>Defs/ThingDef[defName="Mousekin_HatWoodsman"]/statBases/StuffEffectMultiplierArmor</xpath>
				<value>
					<StuffEffectMultiplierArmor>2</StuffEffectMultiplierArmor>
				</value>
			</li>
			
			<li Class="PatchOperationReplace">
				<xpath>Defs/ThingDef[defName="Mousekin_HatHeadscarf"]/statBases/ArmorRating_Sharp</xpath>
				<value>
					<ArmorRating_Sharp>0.01</ArmorRating_Sharp>
				</value>
			</li>
			
			<li Class="PatchOperationReplace">
				<xpath>Defs/ThingDef[
						defName="Mousekin_HelmetKettle" or 
						defName="Mousekin_HelmetKnight" or 
						defName="Mousekin_HelmetKnightCommander" or 
						defName="Mousekin_HelmetMorion"
					]/statBases/ArmorRating_Sharp</xpath>
				<value>
					<ArmorRating_Sharp>2.6</ArmorRating_Sharp>
				</value>
			</li>

			<li Class="PatchOperationAdd">
				<xpath>Defs/ThingDef[defName="Mousekin_HatHeadscarf"]/statBases</xpath>
				<value>
					<ArmorRating_Blunt>0.015</ArmorRating_Blunt>
				</value>
			</li>
			
			<li Class="PatchOperationReplace">
				<xpath>Defs/ThingDef[
						defName="Mousekin_HelmetKettle" or 
						defName="Mousekin_HelmetKnight" or 
						defName="Mousekin_HelmetKnightCommander" or 
						defName="Mousekin_HelmetMorion"
					]/statBases/ArmorRating_Blunt</xpath>
				<value>
					<ArmorRating_Blunt>3.4</ArmorRating_Blunt>
				</value>
			</li>
			
			<!-- Disable armor coverage for ears in headgear (Mousekin ears are exposed) -->

			<li Class="PatchOperationAddModExtension">
				<xpath>Defs/ThingDef[
					defName="Mousekin_HatHeadscarf" or
					defName="Mousekin_HatNunVeil" or
					defName="Mousekin_HatStraw" or
					defName="Mousekin_HatWoodsman" or
					defName="Mousekin_HelmetKettle" or
					defName="Mousekin_HelmetKnight" or
					defName="Mousekin_HelmetKnightCommander" or 
					defName="Mousekin_HelmetMorion"
				]</xpath>
				<value>
					<li Class="CombatExtended.PartialArmorExt">
						<stats>
							<li>
								<ArmorRating_Sharp>0</ArmorRating_Sharp>
								<parts>
									<li>Mousekin_Ear</li>
								</parts>
							</li>
							<li>
								<ArmorRating_Blunt>0</ArmorRating_Blunt>
								<parts>
									<li>Mousekin_Ear</li>
								</parts>
							</li>
						</stats>
					</li>
				</value>
			</li>

			<!-- Patch accessory bulk and stats -->
			
			<li Class="PatchOperationAdd">
				<xpath>Defs/ThingDef[defName="Mousekin_BackpackLeather"]/statBases</xpath>
				<value>
					<Bulk>3</Bulk>
				</value>
			</li>
			
			<li Class="PatchOperationAdd">
				<xpath>Defs/ThingDef[defName="Mousekin_BackpackWicker"]/statBases</xpath>
				<value>
					<Bulk>10</Bulk>
				</value>
			</li>
			
			<li Class="PatchOperationAdd">
				<xpath>Defs/ThingDef[defName="Mousekin_GlassesSmall"]/statBases</xpath>
				<value>
					<Bulk>0.05</Bulk>
					<!-- Negligible worn bulk -->
				</value>
			</li>
			
			<li Class="PatchOperationAdd">
				<xpath>Defs/ThingDef[defName="Mousekin_GlassesLarge"]/statBases</xpath>
				<value>
					<Bulk>0.1</Bulk>
					<!-- Negligible worn bulk -->
				</value>
			</li>
			
			<li Class="PatchOperationAdd">
				<xpath>Defs/ThingDef[defName="Mousekin_BackpackLeather"]/equippedStatOffsets</xpath>
				<value>
					<CarryBulk>30</CarryBulk>
				</value>
			</li>
			
			<li Class="PatchOperationAdd">
				<xpath>Defs/ThingDef[defName="Mousekin_BackpackWicker"]/equippedStatOffsets</xpath>
				<value>
					<CarryBulk>55</CarryBulk>
				</value>
			</li>
			
			<!-- Use CE backpack apparel layer for Mousekin backpacks -->
			
			<li Class="PatchOperationReplace">
				<xpath>Defs/ThingDef[
					defName="Mousekin_BackpackLeather" or
					defName="Mousekin_BackpackWicker"
				]/apparel/layers/li[text()='Belt']</xpath>
				<value>
					<li>Backpack</li>
				</value>
			</li>
			
			<!-- Patch shields -->
			
			<li Class="PatchOperationReplace">
				<xpath>Defs/ThingDef[@Name="Mousekin_ShieldMakeableBase"]/thingClass</xpath>
				<value>
					<thingClass>CombatExtended.Apparel_Shield</thingClass>
				</value>
			</li>
			
			<li Class="PatchOperationReplace">
				<xpath>Defs/ThingDef[@Name="Mousekin_ShieldMakeableBase"]/apparel/bodyPartGroups</xpath>
				<value>
					<bodyPartGroups>
						<li>LeftShoulder</li>
					</bodyPartGroups>
				</value>
			</li>
			
			<li Class="PatchOperationReplace">
				<xpath>Defs/ThingDef[@Name="Mousekin_ShieldMakeableBase"]/apparel/layers</xpath>
				<value>
					<layers>
						<li>Shield</li>
					</layers>
				</value>
			</li>
			
			<li Class="PatchOperationRemove">
				<xpath>Defs/ThingDef[@Name="Mousekin_ShieldMakeableBase"]/tools</xpath>
			</li>
			
			<li Class="PatchOperationReplace">
				<xpath>Defs/ThingDef[@Name="Mousekin_ShieldMakeableBase"]/equippedStatOffsets</xpath>
				<value>
					<equippedStatOffsets>
						<ReloadSpeed>-0.2</ReloadSpeed>
						<MeleeHitChance>-1</MeleeHitChance>
						<ShootingAccuracyPawn>-0.15</ShootingAccuracyPawn>
						<AimingAccuracy>-0.08</AimingAccuracy>
						<Suppressability>-0.25</Suppressability>
						<MeleeCritChance>-0.05</MeleeCritChance>
						<MeleeParryChance>1.0</MeleeParryChance>
					</equippedStatOffsets>
				</value>
			</li>
			
			<li Class="PatchOperationAddModExtension">
				<xpath>Defs/ThingDef[@Name="Mousekin_ShieldMakeableBase"]</xpath>
				<value>
					<li Class="CombatExtended.ShieldDefExtension">
						<shieldCoverage>
							<li>Hands</li>
							<li>Arms</li>
							<li>Shoulders</li>
							<li>Torso</li>
							<li>Neck</li>
						</shieldCoverage>
					</li>
				</value>
			</li>
			
			<li Class="PatchOperationRemove">
				<xpath>Defs/ThingDef[
					defName="Mousekin_ShieldGuardener" or 
					defName="Mousekin_ShieldKnight"
				]/comps/li[@Class="VEF.Apparels.CompProperties_Shield"]</xpath>
			</li>
			
			<li Class="PatchOperationAdd">
				<xpath>Defs/ThingDef[
					defName="Mousekin_ShieldGuardener" or
					defName="Mousekin_ShieldKnight"
				]/statBases </xpath>
				<value>
					<Bulk>6</Bulk>
					<WornBulk>4</WornBulk>
				</value>
			</li>
			
			<li Class="PatchOperationReplace">
				<xpath>Defs/ThingDef[defName="Mousekin_ShieldGuardener"]/statBases/ArmorRating_Sharp</xpath>
				<value>
					<ArmorRating_Sharp>1.5</ArmorRating_Sharp>
				</value>
			</li>

			<li Class="PatchOperationReplace">
				<xpath>Defs/ThingDef[defName="Mousekin_ShieldGuardener"]/statBases/ArmorRating_Blunt</xpath>
				<value>
					<ArmorRating_Blunt>2.6</ArmorRating_Blunt>
				</value>
			</li>
			
			<li Class="PatchOperationAdd">
				<xpath>Defs/ThingDef[defName="Mousekin_ShieldGuardener"]</xpath>
				<value>
					<apparel>
						<renderNodeProperties>
							<li>
								<nodeClass>CombatExtended.PawnRenderNode_Apparel</nodeClass>
								<workerClass>CombatExtended.PawnRenderNodeWorker_Drafted</workerClass>
								<texPath>Things/Items/Equipment/MousekinShieldGuardener/MousekinShieldGuardener</texPath>
								<shaderTypeDef>CutoutComplex</shaderTypeDef>
								<parentTagDef>ApparelBody</parentTagDef>
								<drawData>
									<scale>0.6</scale>
									<defaultData>
										<layer>85</layer>
									</defaultData>
									<dataEast>
										<layer>-5</layer>
										<offset>(0, 0, -0.2)</offset>
										<rotationOffset>30</rotationOffset>
									</dataEast>
									<dataWest>
										<rotationOffset>-30</rotationOffset>
									</dataWest>
									<dataNorth>
										<layer>-5</layer>
										<offset>(-0.2, 0, -0.175)</offset>
									</dataNorth>
									<dataSouth>
										<offset>(0.2, 0, -0.2)</offset>
									</dataSouth>
								</drawData>
							</li>
						</renderNodeProperties>
					</apparel>
				</value>
			</li>
			
			<li Class="PatchOperationReplace">
				<xpath>Defs/ThingDef[defName="Mousekin_ShieldKnight"]/statBases/ArmorRating_Sharp</xpath>
				<value>
					<ArmorRating_Sharp>3</ArmorRating_Sharp>
				</value>
			</li>

			<li Class="PatchOperationReplace">
				<xpath>Defs/ThingDef[defName="Mousekin_ShieldKnight"]/statBases/ArmorRating_Blunt</xpath>
				<value>
					<ArmorRating_Blunt>4.5</ArmorRating_Blunt>
				</value>
			</li>
			
			<li Class="PatchOperationAdd">
				<xpath>Defs/ThingDef[defName="Mousekin_ShieldKnight"]</xpath>
				<value>
					<apparel>
						<renderNodeProperties>
							<li>
								<nodeClass>CombatExtended.PawnRenderNode_Apparel</nodeClass>
								<workerClass>CombatExtended.PawnRenderNodeWorker_Drafted</workerClass>
								<texPath>Things/Items/Equipment/MousekinShieldKnight/MousekinShieldKnight</texPath>
								<shaderTypeDef>Cutout</shaderTypeDef>
								<parentTagDef>ApparelBody</parentTagDef>
								<drawData>
									<scale>0.55</scale>
									<defaultData>
										<layer>85</layer>
									</defaultData>
									<dataEast>
										<layer>-5</layer>
										<offset>(0, 0, -0.25)</offset>
										<rotationOffset>30</rotationOffset>
									</dataEast>
									<dataWest>
										<rotationOffset>-30</rotationOffset>
									</dataWest>
									<dataNorth>
										<layer>-5</layer>
										<offset>(-0.2, 0, -0.2)</offset>
									</dataNorth>
									<dataSouth>
										<offset>(0.2, 0, -0.2)</offset>
									</dataSouth>
								</drawData>
							</li>
						</renderNodeProperties>
					</apparel>
				</value>
			</li>
			
		</operations>
	</Operation>
</Patch>
